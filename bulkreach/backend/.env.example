SECRET_KEY=your-django-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgres://bulkreach:password@localhost:5432/bulkreach

REDIS_URL=redis://localhost:6379/0

# Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback/

# SMTP Fallback
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Security
FIELD_ENCRYPTION_KEY=your-32-byte-encryption-key-base64-encoded
JWT_SECRET_KEY=your-jwt-secret-key

# Postgres (used by Docker)
POSTGRES_DB=bulkreach
POSTGRES_USER=bulkreach
POSTGRES_PASSWORD=password

# Django Settings Module
DJANGO_SETTINGS_MODULE=config.settings.development
